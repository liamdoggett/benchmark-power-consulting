{
  "name": "benchmark-power-consulting",
  "version": "1.0.0",
  "description": "Benchmark Power Consulting — modern executive consulting website",
  "scripts": {
    "dev": "npx tailwindcss -i ./src/input.css -o ./css/styles.css --watch",
